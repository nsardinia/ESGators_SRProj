PORT=5000
FRONTEND_URL=https://es-gators.vercel.app
CORS_ORIGINS=https://es-gators.vercel.app

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Grafana Cloud remote write
GRAFANA_USERNAME=your-grafana-instance-id
GRAFANA_API_KEY=your-grafana-api-key
GRAFANA_PUSH_URL=https://prometheus-prod-xx.grafana.net/api/prom/push

# MWBE upstream API
MWBE_API_URL=http://localhost:3000/api/sensors/latest
MWBE_API_METHOD=GET
MWBE_API_TIMEOUT_MS=10000
MWBE_API_HEADERS_JSON={}
MWBE_API_BODY_JSON=null
MWBE_API_RESPONSE_PATH=data.items
MWBE_API_SENSOR_ID_FIELD=sensor_id
MWBE_API_METRIC_FIELD=metric_type
MWBE_API_VALUE_FIELD=value
MWBE_API_TIMESTAMP_FIELD=timestamp
MWBE_SOURCE_NAME=mwbe
MWBE_SYNC_INTERVAL_MS=60000
MWBE_SYNC_ON_START=false

# Firebase RTDB
# The current app flow reuses the signed-in Firebase user token from the frontend
# (same auth session as the Node Map page), so the minimal backend setup only needs
# the RTDB location and path settings below.
FIREBASE_DATABASE_URL=https://senior-project-esgators-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=senior-project-esgators
VITE_FIREBASE_DATABASE_URL=https://senior-project-esgators-default-rtdb.firebaseio.com
FIREBASE_DEVICE_ROOT_PATH=users
FIREBASE_SOURCE_NAME=firebase-rtdb
FIREBASE_SYNC_DEVICE_IDS=
FIREBASE_BACKGROUND_POLLING_ENABLED=false
FIREBASE_SYNC_INTERVAL_MS=5000
FIREBASE_SYNC_ON_START=true
FIREBASE_OWNER_SYNC_INTERVAL_MS=1000

# Optional admin/background access:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"senior-project-esgators","private_key_id":"replace-me","private_key":"-----BEGIN PRIVATE KEY-----\\nreplace-me\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-xxxx@senior-project-esgators.iam.gserviceaccount.com","client_id":"replace-me"}
# FIREBASE_PROJECT_ID=senior-project-esgators
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@senior-project-esgators.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\\nreplace-me\\n-----END PRIVATE KEY-----\\n
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-key.json

# MCP / ChatGPT integration
MCP_BACKEND_BASE_URL=http://localhost:5000
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_PATH=/mcp
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/responses
OPENAI_MODEL=gpt-5
OPENAI_MCP_SERVER_URL=
OPENAI_MCP_SERVER_LABEL=esgators

# Threshold / ESG tuning
SENSOR_THRESHOLDS_JSON={}
ESG_SCORE_MODE=streaming
ESG_BUFFER_SIZE=5000
ESG_WINDOW_MS=3600000
ESG_METRIC_WEIGHTS_JSON={}
